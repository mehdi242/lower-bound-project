% inference rules
\newcommand*{\rlname}[3]{\ifx\\#3\\#2\else\ensuremath{#3}\fi}
\newcommand*{\rlstyle}[1]{\textcolor{violet}{\textsc{#1}}} %
\newcommand*{\rllabelstyle}[1]{\!\!\scalebox{0.8}{\rlstyle{[#1]}}}
\newcommandx{\InferDef}[5][1=,2=,3=]{%
  \expandarg
  \def\lbl{\rlname{#1}{#2}{#3}}
  \infer[\unlessempty{#1#2}{\rllabelstyle{\hypertarget{#1:#2}{\lbl}}}]{#4}{#5}%
  \unlessempty{#1#2}{\customlabel{#1:#2}{\textsc{(\rlname{#1}{#2}{#3})}}}
}
\newcommandx{\InferStar}[4][1=,2=]{%
  \infer[\unlessempty{#2}{\rllabelstyle{\ref{#1:#2}}}]{#3}{#4}}
\NewDocumentCommand\Infer{s}{\IfBooleanTF#1\InferStar\InferDef}
